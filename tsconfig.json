{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "game-kit": ["./vendor/game-kit/src/index.ts"],
      "game-kit/*": ["./vendor/game-kit/src/*/index.ts"]
    }
  },
  "include": ["src"]
}
